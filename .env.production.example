# .env.production.example — copy to .env on VPS and fill in real values
# Do NOT commit this file with real secrets.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user_invone:CHANGE_PASSWORD@localhost:5432/invone_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (generate with: openssl rand -hex 64) ─────────────────────────────────
JWT_SECRET=CHANGE_ME_64_HEX_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_64_HEX_CHARS_DIFFERENT

# ── VAPID (generate with: npx web-push generate-vapid-keys) ───────────────────
VAPID_PUBLIC_KEY=CHANGE_ME_VAPID_PUBLIC
VAPID_PRIVATE_KEY=CHANGE_ME_VAPID_PRIVATE
VAPID_EMAIL=admin@autopostvn.cloud
NEXT_PUBLIC_VAPID_PUBLIC_KEY=CHANGE_ME_VAPID_PUBLIC   # must match VAPID_PUBLIC_KEY

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=CHANGE_ME_GEMINI_KEY
GEMINI_MODEL=gemini-2.0-flash-lite

# ── App URLs — MUST be set before `next build` ────────────────────────────────
NODE_ENV=production
APP_URL=https://autopostvn.cloud
FRONTEND_URL=https://autopostvn.cloud
FRONTEND_URLS=https://autopostvn.cloud,https://www.autopostvn.cloud
NEXT_PUBLIC_API_URL=https://api.autopostvn.cloud
API_PORT=3001

# ── Encryption key (AES-256-GCM, 64 hex chars = 32 bytes) ────────────────────
# generate: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS

# ── GDT Intermediary (optional — leave empty to disable) ─────────────────────
GDT_INTERMEDIARY_BASE_URL=
GDT_INTERMEDIARY_TOKEN_URL=
GDT_INTERMEDIARY_CLIENT_ID=
GDT_INTERMEDIARY_CLIENT_SECRET=
GDT_INTERMEDIARY_SCOPE=invoice:read
